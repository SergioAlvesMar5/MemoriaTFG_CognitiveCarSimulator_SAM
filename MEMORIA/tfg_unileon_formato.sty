\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{tfg_unileon_formato}[2026/07/01 Formato TFG Universidad de Leon]

\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage[spanish,es-tabla]{babel}
\RequirePackage{lmodern}
\RequirePackage[scaled=0.95]{helvet}
\RequirePackage{geometry}
\RequirePackage{setspace}
\RequirePackage{graphicx}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{longtable}
\RequirePackage{tabularx}
\RequirePackage{float}
\RequirePackage{caption}
\RequirePackage{enumitem}
\RequirePackage{titlesec}
\RequirePackage{needspace}
\RequirePackage{etoolbox}
\RequirePackage{fancyhdr}
\RequirePackage[hidelinks,hypertexnames=false]{hyperref}

\geometry{
  top=3cm,
  left=3cm,
  bottom=2.5cm,
  right=2.5cm
}

\onehalfspacing
\renewcommand{\familydefault}{\sfdefault}
\raggedbottom
\setlength{\parindent}{1.25cm}
\setlength{\parskip}{0pt}
\setlength{\headheight}{15pt}
\setlength{\emergencystretch}{3em}
\clubpenalty=10000
\widowpenalty=10000
\displaywidowpenalty=10000
\brokenpenalty=10000
\interlinepenalty=10000

\captionsetup{font=normalsize,labelfont=bf,justification=centering,labelsep=period}
\captionsetup[table]{position=top}
\captionsetup[figure]{position=top}

\setlist[itemize]{leftmargin=*,topsep=4pt,itemsep=3pt,parsep=0pt,partopsep=0pt}
\setlist[enumerate]{leftmargin=*,topsep=4pt,itemsep=3pt,parsep=0pt,partopsep=0pt}

\newcommand{\tfgfootertext}{}
\newcolumntype{L}[1]{>{\raggedright\arraybackslash}p{#1}}

\titleformat{\chapter}[display]
  {\bfseries\fontsize{28}{34}\selectfont}
  {\chaptertitlename\ \thechapter}
  {12pt}
  {}
  [\vspace{12pt}]
\titlespacing*{\chapter}{0pt}{0pt}{12pt}

\titleformat{\section}
  {\bfseries\fontsize{14}{16}\selectfont}
  {\thesection}
  {1em}
  {\MakeUppercase}
\titlespacing*{\section}{0pt}{12pt}{12pt}
\pretocmd{\section}{\Needspace{5\baselineskip}}{}{}

\titleformat{\subsection}
  {\bfseries\normalsize}
  {\thesubsection}
  {1em}
  {}
\titlespacing*{\subsection}{0pt}{12pt}{6pt}
\pretocmd{\subsection}{\Needspace{4\baselineskip}}{}{}

\fancypagestyle{frontmatter}{%
  \fancyhf{}%
  \fancyhead[R]{\thepage}%
  \fancyfoot[L]{\tfgfootertext}%
  \renewcommand{\headrulewidth}{0.4pt}%
  \renewcommand{\footrulewidth}{0.4pt}%
}

\fancypagestyle{mainmatter}{%
  \fancyhf{}%
  \fancyhead[R]{\thepage/\pageref{LastMainPage}}%
  \fancyfoot[L]{\tfgfootertext}%
  \renewcommand{\headrulewidth}{0.4pt}%
  \renewcommand{\footrulewidth}{0.4pt}%
}

\fancypagestyle{appendixmatter}{%
  \fancyhf{}%
  \fancyhead[R]{\thepage}%
  \fancyfoot[L]{\tfgfootertext}%
  \renewcommand{\headrulewidth}{0.4pt}%
  \renewcommand{\footrulewidth}{0.4pt}%
}

\makeatletter
\renewcommand*\l@section{\@dottedtocline{1}{1.5em}{3.2em}}
\renewcommand*\l@subsection{\@dottedtocline{2}{4.7em}{3.9em}}
\newcommand{\listoffigureswithprefix}{%
  \begingroup
  \renewcommand*\l@figure{\@dottedtocline{1}{1.5em}{5.6em}}%
  \let\originalnumberline\numberline
  \renewcommand{\numberline}[1]{\originalnumberline{Figura~##1}}%
  \listoffigures
  \endgroup
}
\newcommand{\listoftableswithprefix}{%
  \begingroup
  \renewcommand*\l@table{\@dottedtocline{1}{1.5em}{5.2em}}%
  \let\originalnumberline\numberline
  \renewcommand{\numberline}[1]{\originalnumberline{Tabla~##1}}%
  \listoftables
  \endgroup
}
\makeatother
